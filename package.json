{
  "name": "ig-dm-automation",
  "version": "1.0.0",
  "description": "Social Media Lead Automation Command Center ($0 Budget)",
  "main": "backend/server.js",
  "scripts": {
    "server": "node backend/server.js",
    "server:watch": "nodemon backend/server.js",
    "client": "vite --port 3000 --host",
    "dev": "concurrently --kill-others \"npm run server\" \"npm run client\"",
    "build": "vite build --outDir dist"
  },
  "dependencies": {
    "axios": "^1.6.8",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "pg": "^8.11.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.0",
    "vite": "^5.2.11"
  },
  "private": true
}
