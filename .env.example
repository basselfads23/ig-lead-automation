# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (Leave empty to use SQLite)
# For production, you can paste your Supabase PostgreSQL connection string here:
# DATABASE_URL=postgresql://postgres:[password]@db.[project-id].supabase.co:5432/postgres

# Meta API (Instagram & Facebook)
# You will get these from developers.facebook.com for free
META_PAGE_ACCESS_TOKEN=your_meta_page_access_token_here
META_APP_SECRET=your_meta_app_secret_here
META_VERIFY_TOKEN=your_custom_webhook_verify_token_here

# TikTok Developer API
TIKTOK_CLIENT_KEY=your_tiktok_client_key_here
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret_here
TIKTOK_WEBHOOK_SECRET=your_tiktok_webhook_secret_here
